{
  "name": "webapi",
  "version": "1.0.0",
  "description": "Expense management API built with Node.js, Express and TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "migrate": "tsx src/scripts/migrate.ts"
  },
  "keywords": [
    "nodejs",
    "express",
    "typescript",
    "swagger"
  ],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.2.2",
    "express": "^5.2.1",
    "mssql": "^11.0.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/mssql": "^9.1.8",
    "@types/node": "^26.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
